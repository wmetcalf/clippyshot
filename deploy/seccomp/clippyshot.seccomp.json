    {
      "_comment": "socket() restricted to AF_UNIX(1), AF_LOCAL(1) only. All networking-capable address families blocked. Namespace --network=none already prevents egress, this is defense-in-depth.",
      "names": ["socket"],
      "action": "SCMP_ACT_ALLOW",
      "args": [
        {
          "index": 0,
          "value": 1,
          "op": "SCMP_CMP_EQ"
        }
