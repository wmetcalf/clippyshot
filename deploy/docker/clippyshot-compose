#!/usr/bin/env bash
# Wrapper for `docker compose` that auto-detects the host's docker-socket
# GID and writes it to deploy/docker/.env so the dispatcher container's
# `group_add` matches the host socket's group. Without this, the
# dispatcher (running as UID 10001) can't read /var/run/docker.sock and
# fails to launch worker containers.
#
# Usage — same as `docker compose`:
#   ./deploy/docker/clippyshot-compose up -d
#   ./deploy/docker/clippyshot-compose logs -f dispatcher
#   ./deploy/docker/clippyshot-compose down
#
# Why not just let compose use ${DOCKER_GID:-984}? The default GID (984)
# is correct on some distros (RHEL derivatives) and wrong on Ubuntu
# (110), Debian (999, varies), and anywhere the admin ran `groupadd`
# manually. Auto-detecting from the actual socket is the only reliably
# portable pick.
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

DOCKER_SOCK="${DOCKER_SOCK:-/var/run/docker.sock}"
if [ -S "$DOCKER_SOCK" ]; then
    SOCKET_GID="$(stat -c '%g' "$DOCKER_SOCK")"
elif [ -n "${DOCKER_GID:-}" ]; then
    echo "note: $DOCKER_SOCK not found; using DOCKER_GID=$DOCKER_GID from env" >&2
    SOCKET_GID="$DOCKER_GID"
else
    echo "error: $DOCKER_SOCK not found and DOCKER_GID env is unset" >&2
    echo "       point DOCKER_SOCK at the real socket or export DOCKER_GID" >&2
    exit 1
fi

# Write DOCKER_GID into deploy/docker/.env without clobbering other vars
# the operator may have set (CLIPPYSHOT_ENABLE_OCR, CLIPPYSHOT_WORKER_*, etc.).
touch .env
grep -v '^DOCKER_GID=' .env > .env.tmp || true
mv .env.tmp .env
echo "DOCKER_GID=$SOCKET_GID" >> .env

exec docker compose "$@"
